<Window x:Class="OnScreenTranslator.ui.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnScreenTranslator.ui"
        mc:Ignorable="d"
        DataContext="{StaticResource Loc}"
        Title="{Binding Guide}" MaxHeight="600" SizeToContent="Height" Width="500"
        Background="#1E1E1E" ThemeMode="Dark" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HowToUse}" Foreground="White" FontSize="18" 
                   FontWeight="Bold" Margin="0 0 0 15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Основні кроки:" FontWeight="Bold" Margin="0 5"/>
                <TextBlock TextWrapping="Wrap" Margin="10 0 0 10">
                    1. Вибрати область для перекладу за допомогою кнопки 'Вибрати область' або (Alt + Q). <LineBreak/>
                    2.  <LineBreak/>
                    3. Переклад з'явиться в напівпрозорому вікні поверх екрана.
                </TextBlock>

                <TextBlock Text="Гарячі клавіші (Hotkeys):" FontWeight="Bold" Margin="0 5"/>
                <Border Background="#2D2D2D" Padding="10" CornerRadius="5">
                    <StackPanel>
                        <Grid Margin="0 0 0 7">
                            <Border Width="45" Height="17" Background="#3D3D3D" HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <TextBlock Text="Alt + Q" HorizontalAlignment="Center" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Вибрати область для перекладу" Margin="60 0 0 0" Foreground="White"/>
                        </Grid>
                        
                        <Grid Margin="0 0 0 7">
                            <Border Width="45" Height="17" Background="#3D3D3D" HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <TextBlock Text="Alt + O" HorizontalAlignment="Center" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Створити/сховати оверлей" Margin="60 0 0 0" Foreground="White"/>
                        </Grid>

                        <Grid Margin="0 0 0 7">
                            <Border Width="45" Height="17" Background="#3D3D3D" HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <TextBlock Text="Alt + L" HorizontalAlignment="Center" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Закріпити/відкріпити оверлей" Margin="60 0 0 0" Foreground="White"/>
                        </Grid>

                        <Grid Margin="0">
                            <Border Width="45" Height="17" Background="#3D3D3D" HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <TextBlock Text="Alt + T" HorizontalAlignment="Center" Foreground="White"/>
                            </Border>
                            <TextBlock Text="Почати/зупинити процес перекладу" Margin="60 0 0 0" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Порада:" FontWeight="Bold" Margin="0 15 0 5"/>
                <TextBlock TextWrapping="Wrap" FontStyle="Italic">
                    Ви можете налаштувати інтервал оновлення та прозорість вікна у меню 'Параметри'.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
