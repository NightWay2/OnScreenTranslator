<Window x:Class="OnScreenTranslator.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnScreenTranslator.ui"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" ThemeMode="Dark" MinHeight="450" MinWidth="800">

    <Grid>
        <!-- Left menu for overlay stuff -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="OverlayMenu" Width="200" />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Toggle button to spawn and despawn overlay window -->
        <ToggleButton Name="tlgBtnOverlaySwitch" Content="Spawn Overlay" Height="55" Width="120" 
                  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,25,0,0" 
                      Checked="tlgBtnOverlaySwitch_Checked" Unchecked="tlgBtnOverlaySwitch_Uchecked"/>

        <!-- Toggle button to lock and unlock overlay window -->
        <ToggleButton Name="tlgBtnOverlayLock" Content="Lock Overlay" Height="55" Width="120" 
                  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,105,0,0" IsEnabled="False" 
                      Checked="tlgBtnOverlayLock_Checked" Unchecked="tlgBtnOverlayLock_Unchecked"/>

        <!-- Button for selecting area to translate from -->
        <Button Name="btnAreaSelection" Height="55" Width="120" 
                  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,185,0,0" >
            <TextBlock Text="Select Area To Translate From" TextWrapping="Wrap" TextAlignment="Center" />
        </Button>

        <!-- Button to open settings -->
        <Button Name="btnSettingsOpen" Content="Translator Settings" Height="55" Width="120" 
          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" />

        <!-- Right part of grid -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Settings background -->
            <Border Grid.Column="1" Grid.Row="1" Background="DarkGray" CornerRadius="7, 0, 0, 0" />
        </Grid>


    </Grid>
</Window>
