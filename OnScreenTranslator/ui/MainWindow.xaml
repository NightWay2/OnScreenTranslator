<Window x:Class="OnScreenTranslator.ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnScreenTranslator.ui"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Title="OnScreenTranslator" Height="450" Width="800" ThemeMode="Dark" MinHeight="450" MinWidth="800">

    <Grid>
        <!-- Left menu for overlay stuff -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="OverlayMenu" Width="200" />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Toggle button to create and destroy overlay window -->
        <ToggleButton Name="TlgBtnOverlayCreateDestroy" Content="Spawn Overlay" Height="55" Width="120" 
                  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,25,0,0" 
                      Checked="CreateOverlayWindow" Unchecked="DestroyOverlayWindow"/>

        <!-- Toggle button to lock and unlock overlay window -->
        <ToggleButton Name="TlgBtnOverlayLockUnlock" Content="Lock Overlay" Height="55" Width="120" 
                  HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,105,0,0" IsEnabled="False" 
                      Checked="LockOverlayWindow" Unchecked="UnlockOverlayWindow"/>

        <!-- Button for selecting area to translate from -->
        <Button Name="BtnAreaSelection" Height="55" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top" 
                Margin="0,185,0,0" Click="SelectAreaOnScreen" >
            <TextBlock Text="Select Area To Translate From" TextWrapping="Wrap" TextAlignment="Center" />
        </Button>

        <!-- Button to open settings -->
        <Button Name="BtnSettingsOpen" Content="Translator Settings" Height="55" Width="120" 
          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" />

        <!-- Right part of grid -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <ToggleButton Grid.Column="1" Grid.Row="0" x:Name="TlgBtnStartStopTranslation" Content="Start" Height="45" 
                          Width="100" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 0 10 0" 
                          Checked="StartStopTranslation" Unchecked="StartStopTranslation" IsEnabled="False"/>

            <ComboBox Grid.Column="1" Grid.Row="0" x:Name="ComBoxSourceLang" Height="30" Width="160" 
                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 320 0" 
                      SelectionChanged="LanguageIsChanged" />

            <ComboBox Grid.Column="1" Grid.Row="0" x:Name="ComBoxTargetLang" Height="30" Width="160" 
                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="110 0 0 0" 
                      SelectionChanged="LanguageIsChanged" />

            <!-- Settings background -->
            <Border Grid.Column="1" Grid.Row="1" Background="DarkGray" CornerRadius="7, 0, 0, 0" />
        </Grid>


    </Grid>
</Window>
