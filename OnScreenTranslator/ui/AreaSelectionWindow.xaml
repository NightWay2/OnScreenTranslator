<Window x:Class="OnScreenTranslator.ui.AreaSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnScreenTranslator.ui"
        mc:Ignorable="d"
        Title="AreaSelection"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80000000"
        Topmost="True"
        ShowInTaskbar="False">

    <Canvas x:Name="RootCanvas">
        <!-- Rectangle of selection -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="DodgerBlue"
                   StrokeThickness="2"
                   Fill="#40007ACC"
                   Visibility="Collapsed"/>

        <TextBlock x:Name="SizeText" 
               Foreground="White" 
               FontSize="14" 
               FontWeight="Bold"
               Visibility="Collapsed">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="Black"/>
            </TextBlock.Effect>
        </TextBlock>
    </Canvas>
</Window>
